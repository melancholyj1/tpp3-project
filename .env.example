# === База данных (MongoDB Atlas) ===
# Получите строку подключения на mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname

# === JWT ===
# Любая секретная строка для подписи токенов
JWT_SECRET=your_super_secret_key_here

# === Socket.IO ===
# URL вашего сервера (обычно localhost:3000 для разработки)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# === Foursquare API ===
# Получите ключ на developer.foursquare.com для поиска мест (POI)
FOURSQUARE_API_KEY=your_foursquare_api_key_here
